# .env.example
# Copy this file to .env and paste your Personal Access Token.
#
#   cp .env.example .env
#
# Get a token at: https://dev.azure.com/gameballers/_usersSettings/tokens
# Required scope: Work Items — Read only
#
# .env is gitignored — it will never be committed.

ADO_PAT=paste-your-personal-access-token-here